rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidMemory(data) {
      return data.keys().hasAll(['id', 'title', 'dateAdded']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.dateAdded is number;
    }
    
    match /memories/{memoryId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(memoryId) && memoryId == incoming().id && isValidMemory(incoming());
      allow update: if isSignedIn() && isValidId(memoryId) && isValidMemory(incoming());
      allow delete: if isSignedIn() && isValidId(memoryId);
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'name', 'avatar']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.avatar is string && data.avatar.size() <= 500000;
    }

    match /profiles/{profileId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(profileId) && profileId == incoming().id && isValidProfile(incoming());
      allow update: if isSignedIn() && isValidId(profileId) && isValidProfile(incoming());
      allow delete: if isSignedIn() && isValidId(profileId);
    }

    match /user_state/{keyId} {
      allow read, write: if isSignedIn() && isValidId(keyId);
    }
  }
}
